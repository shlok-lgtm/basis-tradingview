//@version=5
indicator("Basis SII Proxy", shorttitle="SII", overlay=false, precision=1)

// === INPUTS ===
peg_target = input.float(1.0, "Peg Target", tooltip="Target price (1.0 for USD stablecoins)")
peg_weight = input.float(0.60, "Peg Weight", minval=0, maxval=1, step=0.05)
vol_weight = input.float(0.40, "Volume Weight", minval=0, maxval=1, step=0.05)

// === PEG DEVIATION SCORE ===
peg_deviation = math.abs(close - peg_target) / peg_target * 100
peg_score = math.max(0.0, 100.0 - peg_deviation * 2000.0)

// === VOLUME HEALTH SCORE ===
vol_sma = ta.sma(volume, 30)
vol_ratio = vol_sma > 0 ? volume / vol_sma : 0.0
vol_score = math.min(100.0, vol_ratio * 50.0)

// === VOLATILITY PENALTY ===
price_std = ta.stdev(close, 14)
vol_penalty = math.max(0.0, math.min(20.0, price_std * 10000.0))

// === COMPOSITE PROXY SCORE ===
raw_score = peg_score * peg_weight + vol_score * vol_weight
proxy_score = math.max(0.0, math.min(100.0, raw_score - vol_penalty))

// === PLOTTING ===
color score_color = proxy_score >= 85 ? color.new(#22c55e, 0) : proxy_score >= 70 ? color.new(#84cc16, 0) : proxy_score >= 55 ? color.new(#eab308, 0) : proxy_score >= 40 ? color.new(#f97316, 0) : color.new(#ef4444, 0)

plot(proxy_score, "SII Proxy", color=score_color, linewidth=2)
hline(85, "A Grade", color=color.new(#22c55e, 70), linestyle=hline.style_dotted)
hline(70, "B Grade", color=color.new(#84cc16, 70), linestyle=hline.style_dotted)
hline(55, "C Grade", color=color.new(#eab308, 70), linestyle=hline.style_dotted)

// === GRADE LABEL ===
string grade = proxy_score >= 90 ? "A+" : proxy_score >= 85 ? "A" : proxy_score >= 80 ? "A-" : proxy_score >= 75 ? "B+" : proxy_score >= 70 ? "B" : proxy_score >= 65 ? "B-" : proxy_score >= 60 ? "C+" : proxy_score >= 55 ? "C" : proxy_score >= 50 ? "C-" : proxy_score >= 45 ? "D" : "F"

// === INFO TABLE ===
var table info_table = table.new(position.top_right, 1, 4, bgcolor=color.new(#0a0a0a, 20), border_width=1, border_color=color.new(#333333, 0))

if barstate.islast
    table.cell(info_table, 0, 0, "BASIS PROTOCOL", text_color=color.new(#14b8a6, 0), text_size=size.small)
    table.cell(info_table, 0, 1, "SII Proxy: " + str.tostring(math.round(proxy_score, 1)), text_color=score_color, text_size=size.normal)
    table.cell(info_table, 0, 2, "Grade: " + grade, text_color=score_color, text_size=size.normal)
    table.cell(info_table, 0, 3, "Full scores: basis-deploy-guide.replit.app", text_color=color.new(#888888, 0), text_size=size.tiny)

// === ALERTS ===
alertcondition(proxy_score < 60, title="SII Below C", message="Stablecoin SII proxy dropped below C grade (60)")
alertcondition(proxy_score < 45, title="SII Below D", message="Stablecoin SII proxy dropped below D grade (45)")
